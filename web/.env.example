# Kopiér til .env i samme mappe (web/) og tilpas. Committes aldrig (.gitignore).

# SQLite-databasefil til Prisma (relativt til web/).
DATABASE_URL="file:./dev.db"

# Hemmelig nøgle til admin-JWT (middleware + login). Brug en lang tilfældig streng i produktion.
JWT_SECRET="change-me-to-a-long-random-string"

# Første admin-login til panelet (kun til lokal/demo — skift i produktion).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"
